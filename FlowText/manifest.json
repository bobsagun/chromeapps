{
  "manifest_version": 3,
  "name": "Social Post Formatter",
  "version": "1.0",
  "description": "Optimizes social media text for mobile readability.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "permissions": ["clipboardWrite"]
}